{
  "name": "fl-snf-backend",
  "version": "1.0.0",
  "description": "Backend API para FL SNF 2025 - Fundación Loyola",
  "main": "server.js",
  "scripts": {
    "start": "node db/migrate.js && node server.js",
    "dev": "nodemon server.js",
    "seed": "node db/seed.js",
    "test": "echo \"Tests disabled\"",
    "deploy": "bash deploy/deploy.sh all",
    "deploy:backend": "bash deploy/deploy.sh backend",
    "deploy:frontend": "bash deploy/deploy.sh frontend",
    "deploy:check": "bash deploy/deploy.sh check"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1049.0",
    "@aws-sdk/s3-request-presigner": "^3.1049.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.0",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "mysql2": "^3.20.0",
    "nodemailer": "^8.0.5",
    "resend": "^6.12.2",
    "uuid": "^9.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2"
  }
}
